{
  "name": "chorvy-crypto",
  "version": "1.0.0",
  "description": "轻量级桌面加解密工具 - 支持拖入图片解密/加密，透明悬浮窗置顶",
  "main": "dist/main.js",
  "scripts": {
    "build:main": "esbuild electron/main.ts --bundle --platform=node --target=node20 --external:electron --outfile=dist/main.js --format=cjs",
    "build:preload": "esbuild electron/preload.ts --bundle --platform=node --target=node20 --external:electron --outfile=dist/preload.js --format=cjs",
    "build:renderer": "esbuild renderer/app.ts --bundle --platform=browser --target=chrome120 --outfile=dist/renderer.js --format=iife && node -e \"require('fs').copyFileSync('renderer/index.html','dist/index.html');require('fs').copyFileSync('renderer/styles.css','dist/styles.css')\"",
    "build": "npm run build:main && npm run build:preload && npm run build:renderer",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "dist": "npm run build && electron-builder"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^26.15.2",
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  },
  "build": {
    "appId": "com.chorvy.crypto",
    "productName": "Chorvy Crypto",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "assets/icon.png",
        "to": "icon.png"
      }
    ],
    "asar": true,
    "asarUnpack": [],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "ChorvyCrypto-${version}.exe"
    },
    "compression": "maximum",
    "electronLanguages": [
      "zh-CN",
      "en-US"
    ]
  }
}